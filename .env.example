# Server
PORT=3000

# Database (Supabase PostgreSQL)
# 本地開發: 使用你的 Supabase 連線字串
# Fly.io 部署: 使用 fly secrets set DATABASE_URL="..."
DATABASE_URL=postgres://postgres:postgres@localhost:5432/virtual_fund_ledger

# JWT Secret (至少 32 字元的強密碼)
# Fly.io 部署: 使用 fly secrets set JWT_SECRET="..."
JWT_SECRET=replace_with_a_strong_secret
